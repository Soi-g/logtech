POSTGRES_IMAGE=postgres:16.3

COLLECTOR_CONTRIB_IMAGE=otel/opentelemetry-collector-contrib:0.114.0
PROMETHEUS_IMAGE=quay.io/prometheus/prometheus:v2.52.0
JAEGERTRACING_IMAGE=jaegertracing/all-in-one:1.57

PROMETHEUS_SERVICE_PORT=9090
PROMETHEUS_SERVICE_HOST=prometheus
PROMETHEUS_ADDR=${PROMETHEUS_SERVICE_HOST}:${PROMETHEUS_SERVICE_PORT}

OTEL_COLLECTOR_HOST=otelcol
OTEL_COLLECTOR_PORT_GRPC=4317
OTEL_COLLECTOR_PORT_HTTP=4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://${OTEL_COLLECTOR_HOST}:${OTEL_COLLECTOR_PORT_GRPC}

# ──────────────────────────────────────────
# AWS OTel Gateway (Envoy endpoint)
# terraform output -raw otel_collector_grpc_endpoint
# ──────────────────────────────────────────
AWS_OTLP_GRPC_ENDPOINT=43.202.21.14:4317

